# Dossier pour les versions de migration Alembic
#
# Les fichiers de migration sont générés avec :
#   alembic revision --autogenerate -m "description"
#   alembic upgrade head
#
# Exemple de fichier : 0001_initial_schema.py
#   """Initial database schema
#
#   Revision ID: 0001
#   Create Date: 2026-06-23
#   """
#   from alembic import op
#   import sqlalchemy as sa
#
#   revision = "0001"
#   down_revision = None
#
#   def upgrade():
#       # Création des tables
#       op.create_table("users", ...)
#       op.create_table("alerts", ...)
#       # ...
#
#   def downgrade():
#       op.drop_table("alerts")
#       op.drop_table("users")
