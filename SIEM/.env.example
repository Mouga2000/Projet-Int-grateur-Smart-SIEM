# ============================================================
# Smart SIEM - Variables d'environnement (.env.example)
# ============================================================
# Copie ce fichier en .env et adapte les valeurs.
#
#   cp .env.example .env
#
# ============================================================

# ---------------------------
# JWT (authentification)
# ---------------------------
SECRET_KEY=remplace-par-une-cle-secrete-aleatoire
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------
# PostgreSQL
# ---------------------------
- DATABASE_URL=postgresql+asyncpg://postgres:Eve-2006%40@host.docker.internal:5432/SmartSiem
- DATABASE_SYNC_URL=postgresql+psycopg2://postgres:Eve-2006%40@host.docker.internal:5432/SmartSiem

# ---------------------------
# Elasticsearch
# ---------------------------
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http

# ---------------------------
# Redis / Celery
# ---------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ---------------------------
# Email (SMTP)
# ---------------------------
# Laisse commente pour desactiver les notifications email.
# Exemple avec Gmail (utiliser un mot de passe d'application) :
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre.email@gmail.com
# SMTP_PASSWORD=votre-mot-de-passe-application
# SMTP_FROM=siem@smart-siem.local

# ---------------------------
# Slack (Webhook)
# ---------------------------
# Laisse commente pour desactiver les notifications Slack.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/XXX/YYY

# ---------------------------
# Integration (Agent externe)
# ---------------------------
AGENT_API_KEY=siem-agent-key-2026

# ---------------------------
# Retention des donnees
# ---------------------------
LOG_RETENTION_DAYS=90
AUDIT_RETENTION_DAYS=365

# ---------------------------
# Archivage
# ---------------------------
ARCHIVE_ENABLED=True
ARCHIVE_DIR=data/archives
ARCHIVE_AFTER_DAYS=90
