# ============================================================
# Smart SIEM - .gitignore
# ============================================================
# À compléter au fur et à mesure du développement
# Liste les fichiers/dossiers à ignorer par Git
#
# Exemples :
venv/
__pycache__/
*.pyc
.env
*.log
#   *.db
#   .vscode/
#   .idea/
#   .DS_Store
#   node_modules/
#   dist/
#   build/
#   .coverage
#   .pytest_cache/
#   *.egg-info/
#   .cache/

.claude

