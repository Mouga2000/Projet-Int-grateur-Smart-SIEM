# ============================================================
# Smart SIEM - .dockerignore
# ============================================================
# À compléter au fur et à mesure du développement
# Liste les fichiers/dossiers exclus du contexte de build Docker
#
# Exemples :
#   .git/
#   .gitignore
#   venv/
#   __pycache__/
#   *.pyc
#   .env
#   *.log
#   *.db
#   .vscode/
#   .idea/
#   .DS_Store
#   .dockerignore
#   docker-compose*.yml
#   README*.md
#   node_modules/
#   data/
#   models/*.joblib
